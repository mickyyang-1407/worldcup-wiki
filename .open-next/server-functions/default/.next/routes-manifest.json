{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/countries/[country]",
      "regex": "^/countries/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcountry": "nxtPcountry"
      },
      "namedRegex": "^/countries/(?<nxtPcountry>[^/]+?)(?:/)?$"
    },
    {
      "page": "/groups/[group]",
      "regex": "^/groups/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgroup": "nxtPgroup"
      },
      "namedRegex": "^/groups/(?<nxtPgroup>[^/]+?)(?:/)?$"
    },
    {
      "page": "/media/[matchId]",
      "regex": "^/media/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmatchId": "nxtPmatchId"
      },
      "namedRegex": "^/media/(?<nxtPmatchId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/news/[id]",
      "regex": "^/news/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/news/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/players/[slug]",
      "regex": "^/players/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/players/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/teams/[team]",
      "regex": "^/teams/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPteam": "nxtPteam"
      },
      "namedRegex": "^/teams/(?<nxtPteam>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
